{
  "name": "@paperclipai/perf",
  "version": "0.0.0",
  "private": true,
  "description": "Performance harness for measuring Paperclip UI before/after optimization changes.",
  "type": "module",
  "scripts": {
    "run-all": "node run-all.mjs",
    "scenario:chat-scroll": "node scenarios/chat-scroll.mjs",
    "scenario:ws-burst": "node scenarios/ws-burst.mjs",
    "scenario:idle-polling": "node scenarios/idle-polling.mjs",
    "scenario:tab-refocus": "node scenarios/tab-refocus.mjs",
    "scenario:cold-load": "node scenarios/cold-load.mjs",
    "bundle": "node bundle/analyze.mjs",
    "lighthouse": "lhci autorun --config=./lighthouse/lhci.config.cjs",
    "compare": "node compare.mjs"
  },
  "dependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.58.2",
    "rollup-plugin-visualizer": "^5.12.0"
  }
}
